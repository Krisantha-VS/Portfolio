@page "/dev/users"
@layout blazor_demo.Layout.DevLayout
@inject TenantApiService Api
@inject NavigationManager Nav

<div class="page-header">
    <h1>Users</h1>
    <p>All registered users across your apps.</p>
</div>

<!-- App selector -->
@if (_apps.Length > 1)
{
    <div class="filter-bar">
        <label class="filter-label">App</label>
        <select class="form-select" @onchange="OnAppChanged">
            @foreach (var a in _apps)
            {
                <option value="@a.Id" selected="@(a.Id == _appId)">@a.Name</option>
            }
        </select>
    </div>
}

@if (_loading)
{
    <div class="empty-state"><div class="spinner"></div></div>
}
else if (_error is not null)
{
    <div class="error-msg">@_error</div>
}
else if (_users.Length == 0)
{
    <div class="empty-state">
        <div class="empty-icon">👥</div>
        <p>No users in this app yet.</p>
    </div>
}
else
{
    <div class="items-list">
        @foreach (var user in _users)
        {
            <div class="item-card">
                <div class="item-card-header">
                    <div class="item-title">
                        <div class="user-avatar-sm">@(user.Email[0].ToString().ToUpper())</div>
                        <div>
                            <div>@(user.Name ?? user.Email)</div>
                            <div style="font-size:0.75rem;color:var(--muted)">@user.Email</div>
                        </div>
                        @if (!user.IsActive)
                        {
                            <span class="status-badge inactive">Disabled</span>
                        }
                        @if (!user.EmailVerified)
                        {
                            <span class="status-badge" style="background:rgba(245,158,11,0.1);color:#f59e0b;border-color:rgba(245,158,11,0.2)">Unverified</span>
                        }
                    </div>
                    <span class="item-date">@user.CreatedAt.ToString("MMM d, yyyy")</span>
                </div>

                <div class="tag-list mt-2">
                    @foreach (var role in user.Roles)
                    {
                        <span class="tag tag-role">@role</span>
                    }
                    @if (user.Roles.Length == 0)
                    {
                        <span class="tag" style="color:var(--muted)">No roles</span>
                    }
                </div>

                <div class="item-actions mt-2">
                    <button class="btn btn-sm btn-ghost" @onclick="() => ToggleUser(user)">
                        @(user.IsActive ? "Disable" : "Enable")
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "appId")] public string? QueryAppId { get; set; }

    private BlazorDemo.Models.TenantAppDto[]      _apps  = [];
    private BlazorDemo.Models.UserWithRolesDto[]   _users = [];
    private string  _appId   = "";
    private bool    _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _apps  = await Api.GetAppsAsync();
            _appId = QueryAppId ?? (_apps.Length > 0 ? _apps[0].Id : "");
            if (_appId != "") _users = await Api.GetUsersAsync(_appId);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task OnAppChanged(ChangeEventArgs e)
    {
        _appId   = e.Value?.ToString() ?? "";
        _loading = true; _error = null;
        try   { _users = await Api.GetUsersAsync(_appId); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task ToggleUser(BlazorDemo.Models.UserWithRolesDto user)
    {
        try
        {
            var updated = await Api.ToggleUserAsync(user.Id, _appId);
            _users = _users.Select(u => u.Id == updated.Id ? updated : u).ToArray();
        }
        catch (Exception ex) { _error = ex.Message; }
    }
}
